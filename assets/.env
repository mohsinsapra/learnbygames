# ─── Web / Production overrides ─────────────────────────────────────────────
# This file is used for web builds (GitHub Pages). Never commit this file.
# Fill in your real production values below.

# ─── API Configuration ──────────────────────────────────────────────────────
API_BASE_URL=https://api.learn-by-games.com/
API_TIMEOUT=20

# ─── Encryption ─────────────────────────────────────────────────────────────
ENCRYPTION_KEY=YourSecretEncryptionKey32ByteLong

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
FIREBASE_WEB_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_WEB_PROJECT_ID=your-project
FIREBASE_WEB_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_WEB_MESSAGING_SENDER_ID=123456789
FIREBASE_WEB_APP_ID=1:123456789:web:abc123

# ─── Analytics ──────────────────────────────────────────────────────────────
CLARITY_PROJECT_ID=your_clarity_project_id

# ─── App Config ─────────────────────────────────────────────────────────────
APP_NAME=learn by games
SUPPORT_EMAIL=support@learn-by-games.com
